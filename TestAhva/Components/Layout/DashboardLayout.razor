@inherits LayoutComponentBase
@inject Microsoft.AspNetCore.Components.Server.ProtectedBrowserStorage.ProtectedSessionStorage ProtectedSessionStore
@inject NavigationManager Navigation

<div class="dashboard-wrapper">
    <!-- Top Header -->
    <header class="dashboard-header">
        <div class="header-left">
            <button class="sidebar-toggle" @onclick="ToggleSidebar">
                <svg width="20" height="20" fill="white" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M2.5 12a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5m0-4a.5.5 0 0 1 .5-.5h10a.5.5 0 0 1 0 1H3a.5.5 0 0 1-.5-.5"/>
                </svg>
            </button>
        </div>
        <div class="header-right">
            <a href="#" class="header-icon" title="Soporte">
                <svg width="18" height="18" fill="white" viewBox="0 0 16 16">
                    <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14m0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16"/>
                    <path d="M5.255 5.786a.237.237 0 0 0 .241.247h.825c.138 0 .248-.113.266-.25.09-.656.54-1.134 1.342-1.134.686 0 1.314.343 1.314 1.168 0 .635-.374.927-.965 1.371-.673.489-1.206 1.06-1.168 1.987l.003.217a.25.25 0 0 0 .25.246h.811a.25.25 0 0 0 .25-.25v-.105c0-.718.273-.927 1.01-1.486.609-.463 1.244-.977 1.244-2.056 0-1.511-1.276-2.241-2.673-2.241-1.267 0-2.655.59-2.75 2.286m1.557 5.763c0 .533.425.927 1.01.927.609 0 1.028-.394 1.028-.927 0-.552-.42-.94-1.029-.94-.584 0-1.009.388-1.009.94"/>
                </svg>
            </a>
            <a href="#" class="header-icon" title="Notificaciones">
                <svg width="18" height="18" fill="white" viewBox="0 0 16 16">
                    <path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2m.995-14.901a1 1 0 1 0-1.99 0A5 5 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7 0-2.42-1.72-4.44-4.005-4.901"/>
                </svg>
            </a>
            <div class="header-user-info">
                <div class="user-avatar">
                    <svg width="18" height="18" fill="white" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                    </svg>
                </div>
                <div class="user-details">
                    <span class="user-name">@userName</span>
                    <span class="user-role">@userRole</span>
                </div>
            </div>
            <button type="button" class="header-logout" @onclick="Logout" title="Cerrar sesión">
                <svg width="18" height="18" fill="white" viewBox="0 0 16 16">
                    <path fill-rule="evenodd" d="M10 12.5a.5.5 0 0 1-.5.5h-8a.5.5 0 0 1-.5-.5v-9a.5.5 0 0 1 .5-.5h8a.5.5 0 0 1 .5.5v2a.5.5 0 0 0 1 0v-2A1.5 1.5 0 0 0 9.5 2h-8A1.5 1.5 0 0 0 0 3.5v9A1.5 1.5 0 0 0 1.5 14h8a1.5 1.5 0 0 0 1.5-1.5v-2a.5.5 0 0 0-1 0z"/>
                    <path fill-rule="evenodd" d="M15.854 8.354a.5.5 0 0 0 0-.708l-3-3a.5.5 0 0 0-.708.708L14.293 7.5H5.5a.5.5 0 0 0 0 1h8.793l-2.147 2.146a.5.5 0 0 0 .708.708z"/>
                </svg>
            </button>
        </div>
    </header>

    <div class="dashboard-body">
        <!-- Sidebar -->
        <aside class="dashboard-sidebar @(sidebarCollapsed ? "collapsed" : "")">
            <nav class="sidebar-nav">
                <a href="/" class="sidebar-icon" title="Inicio">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M8.354 1.146a.5.5 0 0 0-.708 0l-6 6A.5.5 0 0 0 1.5 7.5V14a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5v-3.5h5V14a.5.5 0 0 0 .5.5h3a.5.5 0 0 0 .5-.5V7.5a.5.5 0 0 0-.146-.354z"/>
                    </svg>
                </a>
                <a href="#" class="sidebar-icon active" title="Perfil">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0"/>
                        <path fill-rule="evenodd" d="M0 8a8 8 0 1 1 16 0A8 8 0 0 1 0 8m8-7a7 7 0 0 0-5.468 11.37C3.242 11.226 4.805 10 8 10s4.757 1.225 5.468 2.37A7 7 0 0 0 8 1"/>
                    </svg>
                </a>
                <a href="#" class="sidebar-icon" title="Buscar">
                    <svg width="20" height="20" fill="currentColor" viewBox="0 0 16 16">
                        <path d="M11.742 10.344a6.5 6.5 0 1 0-1.397 1.398h-.001q.044.06.098.115l3.85 3.85a1 1 0 0 0 1.415-1.414l-3.85-3.85a1 1 0 0 0-.115-.1zM12 6.5a5.5 5.5 0 1 1-11 0 5.5 5.5 0 0 1 11 0"/>
                    </svg>
                </a>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="dashboard-main">
            <div class="dashboard-content">
                @Body
            </div>

            <!-- Footer -->
            <footer class="dashboard-footer">
                <div class="footer-container">
                    <div class="peru-logo">
                        <div class="flag-section">
                            <span class="flag-text">PERÚ</span>
                        </div>
                        <div class="text-section">
                            <strong>Presidencia</strong><br/>
                            <span>del Consejo de Ministros</span>
                        </div>
                        <div class="text-section">
                            <strong>Centro Nacional</strong><br/>
                            <span>de Planeamiento Estratégico</span>
                        </div>
                    </div>
                </div>
            </footer>
        </main>
    </div>
</div>

@code {
    private bool sidebarCollapsed = true;
    private string userName = "Usuario";
    private string userRole = "Operador";

    private void ToggleSidebar()
    {
        sidebarCollapsed = !sidebarCollapsed;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var sessionResult = await ProtectedSessionStore.GetAsync<int>("UserId");
                if (sessionResult.Success && sessionResult.Value > 0)
                {
                    // We could look up the user name here if needed
                }
                else
                {
                    Navigation.NavigateTo("/login");
                }
            }
            catch
            {
                Navigation.NavigateTo("/login");
            }
        }
    }

    private async Task Logout()
    {
        try
        {
            await ProtectedSessionStore.DeleteAsync("UserId");
        }
        catch {}
        Navigation.NavigateTo("/login", true);
    }
}
